#!/bin/sh
DIR=$(cd $(dirname "$0"); pwd)
GIT="/usr/local/bin/git"

Rake minify

gemfile_lock=${DIR}/../Gemfile.lock
rm -rf "$gemfile_lock"

tmp_pid=${DIR}/../tmp/pids/unicorn.pid
rm -rf "$tmp_pid"

cat ${DIR}/../title.md ${DIR}/../readme.md ${DIR}/../documentation.md > ${DIR}/../doc/README.md

docgit() {
  cd ${DIR}/../doc
  ${GIT} add . && ${GIT} commit -m "README updated" && ${GIT} push
}

docgit

# GCE Main
rsync -av  --exclude '.*' -e 'ssh -i ~/.ssh/google_compute_engine' "${DIR}/../" yohasebe@34.97.171.94:/home/yohasebe/www/paradocs ;

# yohasebe Doshisha
rsync -av  --exclude '.*' -e 'ssh -p 5522' "${DIR}/../" yohasebe@202.23.170.33:/home/yohasebe/www/paradocs ;

