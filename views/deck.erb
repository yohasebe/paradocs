<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Paradocs: Paragraph-Oriented Document Presentation System</title>
    <meta name="description" content="Presentation Toolkit for Reading Class">
    <meta name="author" content="Yoichiro Hasebe">
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

    <link rel="shortcut icon" href="<%= PREFIX %>ico/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="<%= PREFIX %>/ico/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= PREFIX %>/ico/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= PREFIX %>/ico/favicon-16x16.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@3.9.2/css/reveal.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@3.9.2/css/theme/simple.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.css">
    <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/themes/light-border.css" />

    <%= @css %>
    <!--[if lt IE 9]>
      <script src="https://cdn.jsdelivr.net/npm/html5shiv.min.js@3.7.2/html5shiv.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/respond.js@1.4.2/dest/respond.min.js"></script>
    <![endif]-->
  </head>
  <body>
    <div class="reveal <%= @if_inverted %>">
      <div id="highlighted_cursor"></div>
      <div class="slides">
        <%= @slides %>
      </div>
    </div>
    <div class='additional'>
      <div class='gadgets' id='gadgets'>
        <div class='sticky' data-prevent-swipe>
          <div class='edit_control'><i class='fa fa-pencil'></i><i class='fa fa-eraser'></i><i class='fa fa-close'></i></div>
          <textarea  class='sticky_editor' spellcheck='false'></textarea>
        </div>
        <div class='note' data-prevent-swipe></div>
        <div class='imagenote' data-prevent-swipe data-enlarged='false'>
          <div class='enlarge'><span class='fa fa-plus'></span></div>
        </div>
      </div>
      <div class='switches'>
        <div id='left_switches'>
          <span class='left_switch'><span class='fa fa-sticky-note-o' id='sticky_icon'></span></span>
          <span class='left_switch'><span class='fa fa-circle' id='pointer_icon'></span></span>
          <span class='left_switch'><span class='fa fa-magic' id='playall_icon'></span></span>
          <span class='left_switch'><span class='fa fa-volume-up' id='speaker_icon'></span></span>
        </div>
        <div id='right_switches'>
          <span class='fa fa-arrows-v' id='overview_icon'></span>
        </div>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@3.9.2/js/reveal.js"></script>
    <script src="https://unpkg.com/@popperjs/core@2"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>

    <script>
      var pconf;
      jQuery(function($){  

        var ua = navigator.userAgent.toLowerCase();
        var isMobile = false;
        var isiPhone = (ua.indexOf('iphone') > -1);
        var isiPad = (ua.indexOf('ipad') > -1);
        var isAndroid = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') > -1);
        var isAndroidTablet = (ua.indexOf('android') > -1) && (ua.indexOf('mobile') == -1);
        if(isiPhone || isiPad || isAndroid || isAndroidTablet){
          var punch_url = "https://cdnjs.cloudflare.com/ajax/libs/jqueryui-touch-punch/0.2.3/jquery.ui.touch-punch.min.js";
          var punch_script = document.createElement("script");
          punch_script.src = punch_url;
          document.body.appendChild(punch_script);
        } 

        pconf = jQuery.parseJSON('<%= @config %>');
      });
    </script>

    <script src="<%= PREFIX %>js/paradocs.<%= PARA_VERSION %>.min.js"></script>
  </body>
</html>
