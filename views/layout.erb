<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Paradocs: A Paragraph-Oriented Document Presentation System">
    <meta name="author" content="Yoichiro Hasebe">

    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:site"        content="@yohasebe" />
    <meta property="og:image"         content="https://yohasebe.com/paradocs/img/paradocs.png" />

    <meta property="og:url"           content="https://yohasebe.com/paradocs/" />
    <meta property="og:type"          content="website" />
    <meta property="og:title"         content="Paradocs" />
    <meta property="og:description"   content="A Paragraph-Oriented Document Presentation System" />
    <meta property="og:image"         content="https://yohasebe.com/paradocs/img/paradocs.png" />


    <link rel="shortcut icon" href="<%= PREFIX %>ico/favicon.ico">
    <title>Paradocs: Paragraph-Oriented Document Presentation System</title>

    <link rel="apple-touch-icon" sizes="180x180" href="<%= PREFIX %>/ico/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="<%= PREFIX %>/ico/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= PREFIX %>/ico/favicon-16x16.png">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jquery-ui@1.14.1/dist/themes/base/jquery-ui.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link href="<%= PREFIX %>css/upload.<%= PARA_VERSION %>.min.css" rel="stylesheet">
  </head>

  <%= $GOOGLE_CODE %>

  <body>
  <div id="wrap">
  <div id='top' style='visibility:hidden;' subdir='<%= PREFIX %>'></div>

    <nav class="navbar fixed-top navbar-expand-lg navbar-light ">
      <a class="navbar-brand" href="<%= PREFIX %><%= $current_lang %>">Paradocs</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-item nav-link" href="/paradocs">English</a>
          </li>
          <li class="nav-item">
            <a class="nav-item nav-link" href="/paradocs/ja">日本語</a>
          </li>
          <li class="nav-item">
            <a class="nav-item nav-link emphasized" href="#use">
              <span class='emphasized'><%= @keywords["use"] %></span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-item nav-link" href="#overview"><%= @keywords["overview"] %></a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= @keywords["documentation"] %>
            </a>
            <div class="dropdown-menu" aria-labelledby="navbarDropdown">
              <a class="dropdown-item" href="#bindings"><%= @keywords["keybindings"] %></a>
              <a class="dropdown-item" href="#concepts"><%= @keywords["concepts"] %></a>
              <a class="dropdown-item" href="#blocks"><%= @keywords["blocks"] %></a>
              <a class="dropdown-item" href="#decoration"><%= @keywords["decoration"] %></a>
              <a class="dropdown-item" href="#embedding"><%= @keywords["embedding"] %></a>
              <a class="dropdown-item" href="#additional"><%= @keywords["additional"] %></a>
            </div>
          </li>
        </ul>
      </div>
    </nav>

    <div class="container-fluid logo-container">
      <div class='text-center'>
        <div>
          <span id="logo">
            <img src="/paradocs/img/paradocs.png" />
            <a href="<%= PREFIX %><%= $current_lang %>">Paradocs </a>
          </span>
        </div>
        <div><span class="slogan"> <%= @keywords["slogan"] %></span></div>
      </div>
    </div>

    <div class="container">
      <div id="carouselExampleControls" class="carousel slide" data-bs-ride="carousel" data-bs-interval="8000">
        <div class="carousel-inner">
          <div class="carousel-item active">
            <img src="<%= PREFIX %>/img/linguistics.gif" alt="">
          </div>
          <div class="carousel-item">
            <img src="<%= PREFIX %>/img/quiz.gif" alt="">
          </div>
          <div class="carousel-item">
            <img src="<%= PREFIX %>/img/speech.gif" alt="">
          </div>
        </div>
        <div class='carousel-outer left'>
          <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
            <span class="fa-solid fa-chevron-left" aria-hidden="true" style='color: #555;'></span>
            <span class="visually-hidden">Previous</span>
          </button>
        </div>
        <div class='carousel-outer right'>
          <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
            <span class="fa-solid fa-chevron-right" aria-hidden="true" style='color: #555;'></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </div>

    <div class="container-fluid">
      <div class='row'>
        <div class="col-sm-12 md">
          <div class="more-margin">
            <%= @tldr_html %>
          </div>
        </div>
      </div>
    </div>

    <div class="container-fluid">
      <div class='row'>
        <div class="col-sm-12">
          <div class="more-margin">
            <div id="use" class="anchor"></div>
            <%= yield %>
          </div>
        </div>
      </div>
    </div>

    <hr />

    <div class="container-fluid">
      <div class='row'>
        <div class="col-sm-12 md">
          <div class="more-margin">
            <%= @readme_html %>
          </div>
        </div>
      </div>
    </div>

    <div class="container-fluid">
      <div class='row'>
        <div class="col-sm-12 md">
          <div class="more-margin">
            <div id="fb-root"></div> 
            <script>
              (function(d, s, id) {
                var js, fjs = d.getElementsByTagName(s)[0];
                if (d.getElementById(id)) return;
                js = d.createElement(s); js.id = id;
                js.src = "//connect.facebook.net/en_US/sdk.js#xfbml=1&version=v2.9";
                fjs.parentNode.insertBefore(js, fjs);
              }(document, 'script', 'facebook-jssdk'));
            </script>
            <div class="social">
              <div class="twitter-tweet-fb">
                <a href="https://twitter.com/share" class="twitter-share-button" data-url="https://yohasebe.com/paradocs" data-text="Paradocs: A Paragraph-Oriented Documentation Presentation System">Tweet</a> 
              </div>
              <div class="fb-like" data-href="https://yohasebe.com/paradocs" data-layout="button" data-action="like" data-size="small" data-show-faces="false" data-share="true">
              </div>
            </div>
            <script>
              !function(d,s,id){var js,fjs=d.getElementsByTagName(s)[0],p=/^http:/.test(d.location)?'http':'https';if(!d.getElementById(id)){js=d.createElement(s);js.id=id;js.src=p+'://platform.twitter.com/widgets.js';fjs.parentNode.insertBefore(js,fjs);}}(document, 'script', 'twitter-wjs');
            </script>
          </div>
        </div>
      </div>
    </div>

    <hr />

    <div class="container-fluid">
      <div class='row'>
        <div class="col-sm-12 md">
          <div class="more-margin">
            <%# <h2><%= @keywords["documentation"] %1></h2> %>
            <%= @document_html %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <br />
  <br />
  <div id="footer">
    <p class='text-center text-muted' style='margin-bottom:0; padding: 1em;'>
      Paradocs [Version <%= PARA_VERSION %>]<br />
      <b>Yoichiro Hasebe 2018-2020</b> | <a href='mailto:yohasebe@gmail.com'>E-mail</a> | <a h href='https://yohasebe.com'>Web</a> |
    </p>
  </div>

  <div id="to-top" class="scroll-top ctrl-wrapper">
    <span class="ctrl-inner">
      <span class="fa-solid fa-chevron-up"></span>
    </span>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jquery-ui@1.14.1/dist/jquery-ui.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/ace-builds@1.36.5/src-min-noconflict/ace.js"></script>
  <script>
    var default_lang;
    jQuery(function($){  
      default_lang = '<%= @language %>';
    });
  </script>
  <script src="<%= PREFIX %>js/upload.<%= PARA_VERSION %>.min.js"></script>    
  </body>
</html>
